@startuml
title US070-CD

skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

package "ui.console" #DDDDDD {
    class AddAircraftToCompanyFleetUI {
        - companyId: String
        - aircraftModelId: String
        - engineModelId: String
        - registrationNumber: String
        - registeredCountry: String
        - operationalStatus: String
        - seatsByClass: Map<String, Integer>
        - flightCrewSize: int
        + requestData()
        + displayMessage(message: String)
        + displayError(message: String)
    }
}

package "controller" #DDDDDD {
    class AddAircraftToCompanyFleetController {
        + addAircraftToCompanyFleet(request: AddAircraftToCompanyFleetRequest): AircraftDTO
    }
}

package "application" #DDDDDD {
    class AddAircraftToCompanyFleetService {
        + addAircraftToCompanyFleet(request: AddAircraftToCompanyFleetRequest): AircraftDTO
    }

    class AuthorizationService {
        + isAuthorized(user: User, permission: Permission): boolean
    }

    class AddAircraftToCompanyFleetRequest {
        - companyId: String
        - aircraftModelId: String
        - engineModelId: String
        - registrationNumber: String
        - registeredCountry: String
        - operationalStatus: String
        - seatsByClass: Map<String, Integer>
        - flightCrewSize: int
    }

    class AircraftDTO {
        - registrationNumber: String
        - companyId: String
        - aircraftModelId: String
        - engineModelId: String
        - registeredCountry: String
        - operationalStatus: String
        - totalSeats: int
        - flightCrewSize: int
    }
}

package "domain" #DDDDDD {
    class User {
        - email: Email
        - roles: List<Role>
        + hasPermission(permission: Permission): boolean
    }

    class Role {
        - name: String
        - permissions: List<Permission>
    }

    class Permission {
        - name: String
    }

    class AirTransportCompany {
        - id: String
        - companyName: CompanyName
        - fleet: Fleet
        + addAircraft(aircraft: Aircraft): void
    }

    class Fleet {
        - aircraft: List<Aircraft>
        + addAircraft(aircraft: Aircraft): void
    }

    class CustomerCollaborator {
        - customer: Customer
        - user: User
        - active: boolean
        + belongsTo(customer: Customer): boolean
    }

    abstract class Customer {
        - id: String
        - name: String
    }

    class Aircraft {
        - registrationNumber: AircraftRegistrationNumber
        - company: AirTransportCompany
        - configuration: AircraftConfiguration
        - cabinConfiguration: CabinConfiguration
        - registeredCountry: Country
        - operationalStatus: OperationalStatus
        - flightCrewSize: FlightCrewSize
        + Aircraft(...)
    }

    class FlightCrewSize {
        - value: int
        + FlightCrewSize(value: int)
    }

    class AircraftRegistrationNumber {
        - value: String
        + AircraftRegistrationNumber(value: String)
    }

    class AircraftModel {
        - id: String
        - modelName: AircraftModelName
        - maximumCapacity: int
        - certifiedEngineModels: List<AircraftEngineModel>
        + isEngineCertified(engineModel: AircraftEngineModel): boolean
    }

    class AircraftEngineModel {
        - id: String
        - modelName: EngineModelName
    }

    class AircraftConfiguration {
        - aircraftModel: AircraftModel
        - engineModel: AircraftEngineModel
        + AircraftConfiguration(aircraftModel: AircraftModel, engineModel: AircraftEngineModel)
    }

    class CabinConfiguration {
        - seatsByClass: Map<String, Integer>
        + totalSeats(): int
        + validateAgainstCapacity(maxCapacity: int): boolean
    }

    class OperationalStatus {
        - value: String
    }

    class Country {
        - name: String
        - code: String
    }

    class AircraftConfigurationPolicy {
        + isValidConfiguration(aircraftModel: AircraftModel, engineModel: AircraftEngineModel): boolean
    }

    class CompanyName {
        - value: String
    }

    class AircraftModelName {
        - value: String
    }

    class EngineModelName {
        - value: String
    }

    class Email {
        - value: String
    }
}

package "repository" #DDDDDD {
    interface AirTransportCompanyRepository {
        + findById(companyId: String): Optional<AirTransportCompany>
        + save(company: AirTransportCompany): void
    }

    interface CustomerCollaboratorRepository {
        + findByUser(user: User): Optional<CustomerCollaborator>
    }

    interface AircraftModelRepository {
        + findById(aircraftModelId: String): Optional<AircraftModel>
    }

    interface AircraftEngineModelRepository {
        + findById(engineModelId: String): Optional<AircraftEngineModel>
    }

    interface AircraftRepository {
        + existsByRegistrationNumber(registrationNumber: AircraftRegistrationNumber): boolean
        + save(aircraft: Aircraft): void
    }
}

AddAircraftToCompanyFleetUI --> AddAircraftToCompanyFleetController : uses >
AddAircraftToCompanyFleetController --> AddAircraftToCompanyFleetService : uses >
AddAircraftToCompanyFleetService --> AuthorizationService : checks permission >
AddAircraftToCompanyFleetService --> AirTransportCompanyRepository : retrieves/saves company >
AddAircraftToCompanyFleetService --> CustomerCollaboratorRepository : verifies collaborator company >
AddAircraftToCompanyFleetService --> AircraftModelRepository : retrieves model >
AddAircraftToCompanyFleetService --> AircraftEngineModelRepository : retrieves engine >
AddAircraftToCompanyFleetService --> AircraftRepository : checks/saves aircraft >
AddAircraftToCompanyFleetService --> AircraftConfigurationPolicy : validates configuration >
AddAircraftToCompanyFleetService --> AircraftDTO : returns >
AddAircraftToCompanyFleetService --> FlightCrewSize : creates >

AuthorizationService --> User : checks >
User "1" o-- "1..*" Role
Role "1" o-- "*" Permission
User *-- Email

AirTransportCompany --|> Customer
AirTransportCompany *-- CompanyName
AirTransportCompany *-- Fleet
Fleet "1" o-- "*" Aircraft

CustomerCollaborator "*" --> "1" Customer
CustomerCollaborator "1" --> "1" User

Aircraft "*" --> "1" AirTransportCompany
Aircraft *-- AircraftRegistrationNumber
Aircraft *-- AircraftConfiguration
Aircraft *-- CabinConfiguration
Aircraft *-- Country
Aircraft *-- OperationalStatus
Aircraft *-- FlightCrewSize

AircraftConfiguration "*" --> "1" AircraftModel
AircraftConfiguration "*" --> "1" AircraftEngineModel
AircraftModel *-- AircraftModelName
AircraftEngineModel *-- EngineModelName

@enduml