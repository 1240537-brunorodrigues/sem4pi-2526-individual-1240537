@startuml
title US063-CD

skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

package "ui.console" #DDDDDD {
    class EditCustomerCollaboratorUI {
        - customerId: String
        - collaboratorEmail: String
        - newEmail: String
        - newPhoneNumber: String
        + requestData()
        + displayMessage(message: String)
        + displayError(message: String)
    }
}

package "controller" #DDDDDD {
    class EditCustomerCollaboratorController {
        + editCustomerCollaborator(request: EditCustomerCollaboratorRequest): CustomerCollaboratorDTO
    }
}

package "application" #DDDDDD {
    class EditCustomerCollaboratorService {
        + editCustomerCollaborator(request: EditCustomerCollaboratorRequest): CustomerCollaboratorDTO
    }

    class AuthorizationService {
        + isAuthorized(user: User, permission: Permission): boolean
    }

    class EditCustomerCollaboratorRequest {
        - customerId: String
        - collaboratorEmail: String
        - newEmail: String
        - newPhoneNumber: String
    }

    class CustomerCollaboratorDTO {
        - customerId: String
        - email: String
        - name: String
        - phoneNumber: String
        - position: String
        - active: boolean
    }
}

package "domain" #DDDDDD {
    class User {
        - email: Email
        - name: String
        - phoneNumber: PhoneNumber
        - roles: List<Role>
        - enabled: boolean
        + updateContactInfo(email: Email, phoneNumber: PhoneNumber): void
        + hasPermission(permission: Permission): boolean
    }

    class Role {
        - name: String
        - permissions: List<Permission>
    }

    class Permission {
        - name: String
    }

    abstract class Customer {
        - id: String
        - name: String
    }

    class AirTransportCompany {
        - iataCode: AirlineIATACode
        - icaoCode: AirlineICAOCode
    }

    class AirControlArea {
        - code: AreaCode
    }

    class CustomerCollaborator {
        - customer: Customer
        - user: User
        - position: String
        - active: boolean
        + belongsTo(customer: Customer): boolean
        + updateContactInfo(email: Email, phoneNumber: PhoneNumber): void
    }

    class Email {
        - value: String
        + Email(value: String)
    }

    class PhoneNumber {
        - value: String
        + PhoneNumber(value: String)
    }

    class AirlineIATACode {
        - value: String
    }

    class AirlineICAOCode {
        - value: String
    }

    class AreaCode {
        - value: String
    }
}

package "repository" #DDDDDD {
    interface CustomerRepository {
        + findById(customerId: String): Optional<Customer>
    }

    interface CustomerCollaboratorRepository {
        + findByCustomerAndEmail(customer: Customer, email: Email): Optional<CustomerCollaborator>
        + save(collaborator: CustomerCollaborator): void
    }

    interface UserRepository {
        + existsByEmail(email: Email): boolean
        + save(user: User): void
    }
}

EditCustomerCollaboratorUI --> EditCustomerCollaboratorController : uses >
EditCustomerCollaboratorController --> EditCustomerCollaboratorService : uses >
EditCustomerCollaboratorService --> AuthorizationService : checks permission >
EditCustomerCollaboratorService --> CustomerRepository : retrieves customer >
EditCustomerCollaboratorService --> CustomerCollaboratorRepository : retrieves/saves collaborator >
EditCustomerCollaboratorService --> UserRepository : checks/saves user >
EditCustomerCollaboratorService --> CustomerCollaboratorDTO : returns >

AuthorizationService --> User : checks >
User "1" o-- "1..*" Role
Role "1" o-- "*" Permission
User *-- Email
User *-- PhoneNumber

Customer <|-- AirTransportCompany
Customer <|-- AirControlArea
CustomerCollaborator "*" --> "1" Customer
CustomerCollaborator "1" --> "1" User

AirTransportCompany *-- AirlineIATACode
AirTransportCompany *-- AirlineICAOCode
AirControlArea *-- AreaCode

@enduml