@startuml

hide class
hide circle
hide methods
hide empty members
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

class BackofficeOperator {
    email
}

class Customer {
    id
    name
}

class AirTransportCompany {
    name
    iataCode
    icaoCode
}

class AirControlArea {
    code
    name
}

class CustomerCollaborator {
    email
    name
    phoneNumber
    position
    status
}

class SystemUser {
    email
    name
    phoneNumber
}

class EditableContactInfo {
    email
    phoneNumber
}

Customer <|-- AirTransportCompany
Customer <|-- AirControlArea

BackofficeOperator "1" -- "*" CustomerCollaborator : edits >
Customer "1" -- "*" CustomerCollaborator : has >
CustomerCollaborator "1" -- "1" SystemUser : is >
CustomerCollaborator "1" -- "1" EditableContactInfo : exposes >
EditableContactInfo "1" -- "1" SystemUser : updates >

@enduml