@startuml

hide class
hide circle
hide methods
hide empty members
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

class AirTransportCompanyCollaborator {
    email
    name
    position
}

class AirTransportCompany {
    name
    iataCode
    icaoCode
}

class Fleet {
    aircraft
}

class Aircraft {
    registrationNumber
    operationalStatus
}

class OperationalStatus {
    active
    maintenance
    decommissioned
}

class Flight {
    flightNumber
    status
}

class PendingFlight {
    scheduledDate
}

AirTransportCompanyCollaborator "*" -- "1" AirTransportCompany : belongs to >
AirTransportCompany "1" -- "1" Fleet : has >
Fleet "1" o-- "*" Aircraft : contains >
Aircraft "*" -- "1" AirTransportCompany : owned by >
Aircraft "1" -- "1" OperationalStatus : has >
Aircraft "1" -- "*" Flight : assigned to >
Flight <|-- PendingFlight

@enduml