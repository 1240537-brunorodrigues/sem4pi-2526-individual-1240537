@startuml

hide class
hide circle
hide methods
hide empty members
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

class AirTransportCompanyCollaborator {
    email
    name
    position
}

class AirTransportCompany {
    name
    iataCode
    icaoCode
}

class Pilot {
    name
    email
    phoneNumber
    licenseNumber
    status
}

class SystemUser {
    email
    name
    phoneNumber
    enabled
}

class PilotLicense {
    licenseNumber
}

class PilotCertification {
    certificationDate
    validUntil
}

class AircraftModel {
    modelName
    manufacturer
}

class PilotRoster {
    activePilots
}

class FlightPlan {
    flightNumber
}

AirTransportCompanyCollaborator "*" -- "1" AirTransportCompany : belongs to >
AirTransportCompany "1" -- "*" Pilot : has >
AirTransportCompany "1" -- "1" PilotRoster : has >
PilotRoster "1" o-- "*" Pilot : contains >
Pilot "1" -- "1" SystemUser : is >
Pilot "1" -- "1" PilotLicense : has >
Pilot "1" -- "1..*" PilotCertification : holds >
PilotCertification "*" -- "1" AircraftModel : certifies for >
Pilot "1" -- "*" FlightPlan : may be assigned to >

@enduml