@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam sequenceMessageAlign center
autonumber

actor "Air Transport Company Collaborator" as ATCC
participant ":System" as System

activate ATCC

ATCC -> System : Requests to create a flight route

activate System
System --> ATCC : Requests company, route name,\norigin airport and destination airport
deactivate System

ATCC -> System : Provides flight route data

activate System
System --> System : Check if collaborator is authorized
System --> System : Validate air transport company
System --> System : Check if collaborator belongs to company
System --> System : Validate route name format
System --> System : Check route name uniqueness
System --> System : Validate origin airport
System --> System : Validate destination airport
System --> System : Check if origin and destination are different
System --> System : Check route uniqueness by company, origin and destination

alt route data is valid
    System --> System : Create flight route
    System --> ATCC : Flight route created successfully
else route data is invalid
    System --> ATCC : Display error message
end

deactivate System
deactivate ATCC

@enduml