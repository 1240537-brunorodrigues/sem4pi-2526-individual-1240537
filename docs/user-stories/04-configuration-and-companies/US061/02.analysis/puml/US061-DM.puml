@startuml

hide class
hide circle
hide methods
hide empty members
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

class BackofficeOperator {
    email
}

class Customer {
    id
    name
}

class AirTransportCompany {
    name
    iataCode
    icaoCode
}

class AirControlArea {
    code
    name
}

class CustomerCollaborator {
    email
    name
    phoneNumber
    position
    status
}

class SystemUser {
    email
    name
    phoneNumber
}

class Role {
    name
}

class BootstrapProcess {
    source
}

Customer <|-- AirTransportCompany
Customer <|-- AirControlArea

BackofficeOperator "1" -- "*" CustomerCollaborator : registers >
BootstrapProcess "1" -- "*" CustomerCollaborator : initializes >
Customer "1" -- "*" CustomerCollaborator : has >
CustomerCollaborator "1" -- "1" SystemUser : is >
SystemUser "1" -- "1..*" Role : has >

@enduml