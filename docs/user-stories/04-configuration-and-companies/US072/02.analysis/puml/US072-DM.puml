@startuml

hide class
hide circle
hide methods
hide empty members
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

class AirTransportCompanyCollaborator {
    email
    name
    position
}

class AirTransportCompany {
    name
    iataCode
    icaoCode
}

class Fleet {
    aircraft
}

class Aircraft {
    registrationNumber
    registeredCountry
    operationalStatus
}

class AircraftModel {
    modelName
}

class AircraftEngineModel {
    modelName
}

class AircraftConfiguration {
    aircraftModel
    engineModel
}

class CabinConfiguration {
    totalSeats
}

class OperationalStatus {
    active
    maintenance
    decommissioned
}

AirTransportCompanyCollaborator "*" -- "1" AirTransportCompany : belongs to >
AirTransportCompany "1" -- "1" Fleet : has >
Fleet "1" o-- "*" Aircraft : contains >
Aircraft "*" -- "1" AirTransportCompany : owned by >
Aircraft "1" -- "1" AircraftConfiguration : has >
AircraftConfiguration "*" -- "1" AircraftModel : uses >
AircraftConfiguration "*" -- "1" AircraftEngineModel : uses >
Aircraft "1" -- "1" CabinConfiguration : has >
Aircraft "1" -- "1" OperationalStatus : has >

@enduml