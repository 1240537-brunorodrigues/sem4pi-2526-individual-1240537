@startuml
title US111-CD

skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

package "ui.console" #DDDDDD {
    class GenerateSimulationReportUI {
        - simulationId: String
        + requestData()
        + displaySimulationReport(report: SimulationReportSummaryDTO)
        + displayError(message: String)
    }
}

package "controller" #DDDDDD {
    class GenerateSimulationReportController {
        + generateReport(request: GenerateSimulationReportRequest): SimulationReportSummaryDTO
    }
}

package "application" #DDDDDD {
    class GenerateSimulationReportService {
        + generateReport(request: GenerateSimulationReportRequest): SimulationReportSummaryDTO
    }

    class AuthorizationService {
        + isAuthorized(user: User, permission: Permission): boolean
    }

    class GenerateSimulationReportRequest {
        - simulationId: String
    }

    class SimulationReportStatePolicy {
        + canGenerateReport(simulation: Simulation): boolean
    }

    class SimulationReportSummaryDTO {
        - simulationId: String
        - generatedAt: LocalDateTime
        - totalFlights: int
        - flightExecutionStatuses: List<FlightExecutionStatusDTO>
        - safetyViolationSummaries: List<SafetyViolationSummaryDTO>
        - validationResult: String
        - reportFilePath: String
    }

    class FlightExecutionStatusDTO {
        - flightId: String
        - processId: int
        - status: String
    }

    class SafetyViolationSummaryDTO {
        - timestamp: long
        - positions: List<String>
    }
}

package "integration.c" #DDDDDD {
    class CReportGenerationRunner {
        + requestReport(simulationId: String): CReportOutput
    }

    class CReportOutput {
        - exitCode: int
        - stdout: String
        - stderr: String
    }

    class SimulationReportSummaryOutputParser {
        + parse(output: CReportOutput): SimulationReportSummaryDTO
    }
}

package "domain" #DDDDDD {
    class User {
        - email: Email
        - roles: List<Role>
        + hasPermission(permission: Permission): boolean
    }

    class Role {
        - name: String
        - permissions: List<Permission>
    }

    class Permission {
        - name: String
    }

    class Simulation {
        - simulationId: String
        - status: SimulationStatus
        - startedAt: LocalDateTime
        - endedAt: LocalDateTime
    }

    class SimulationStatus {
        - value: String
        + isFinal(): boolean
    }

    class SimulationReport {
        - reportId: String
        - generatedAt: LocalDateTime
        - totalFlights: int
        - validationResult: String
        - reportFilePath: String
    }

    class Email {
        - value: String
    }
}

package "repository" #DDDDDD {
    interface SimulationRepository {
        + findById(simulationId: String): Optional<Simulation>
    }
}

package "c.simulation.report" #DDDDDD {
    class ReportGenerationThread {
        + generateReportSummary()
    }

    class SimulationReportSummaryBuilder {
        + addSimulationMetadata()
        + addConfiguration()
        + addFlightExecutionStatuses()
        + addSafetyViolationSummaries()
        + addValidationResult()
        + addReportFilePath()
        + build(): SimulationReport
    }

    class SimulationReportSummaryFormatter {
        + format(report: SimulationReport): String
    }
}

package "c.simulation.shared" #DDDDDD {
    class SharedMemoryAccessor {
        + readSimulationMetadata()
        + readConfiguration()
        + readFlightExecutionStatuses()
        + readSafetyViolations()
        + readValidationResult()
        + readReportFilePath()
    }
}

GenerateSimulationReportUI --> GenerateSimulationReportController : uses >
GenerateSimulationReportController --> GenerateSimulationReportService : uses >
GenerateSimulationReportService --> AuthorizationService : checks permission >
GenerateSimulationReportService --> SimulationRepository : retrieves simulation >
GenerateSimulationReportService --> SimulationReportStatePolicy : validates state >
GenerateSimulationReportService --> CReportGenerationRunner : requests C report >
GenerateSimulationReportService --> SimulationReportSummaryOutputParser : parses output >
GenerateSimulationReportService --> SimulationReportSummaryDTO : returns >

CReportGenerationRunner --> CReportOutput : returns >
SimulationReportSummaryOutputParser --> SimulationReportSummaryDTO : creates >

AuthorizationService --> User : checks >
User "1" o-- "1..*" Role
Role "1" o-- "*" Permission
User *-- Email

Simulation *-- SimulationStatus
SimulationRepository --> Simulation : returns >
SimulationReportStatePolicy --> Simulation : checks >

ReportGenerationThread --> SharedMemoryAccessor : reads summary data >
ReportGenerationThread --> SimulationReportSummaryBuilder : builds >
SimulationReportSummaryBuilder --> SimulationReport : creates >
SimulationReportSummaryBuilder --> SimulationReportSummaryFormatter : formats >

@enduml