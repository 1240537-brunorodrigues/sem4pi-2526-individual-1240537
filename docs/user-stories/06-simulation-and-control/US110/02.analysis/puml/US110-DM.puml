@startuml

hide class
hide circle
hide methods
hide empty members
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

class SimulationEngine {
    status
}

class ParentSimulationProcess {
    processId
    currentTimeStep
}

class FlightProcess {
    processId
    flightId
    status
}

class EnvironmentalData {
    timestamp
    windSpeed
    windDirection
    temperature
    pressure
    visibility
    precipitation
}

class EnvironmentalDataSource {
    sourceType
}

class AirControlArea {
    code
    name
}

class TimeStep {
    index
    startTime
    endTime
}

class SharedMemorySegment {
    name
    initialized
}

class EnvironmentalInfluenceModel {
    modelName
}

class AircraftState {
    aircraftId
    latitude
    longitude
    altitude
    fuelQuantity
}

class AdjustedAircraftState {
    aircraftId
    latitude
    longitude
    altitude
    fuelQuantity
    appliedEnvironmentalEffects
}

class EnvironmentalPolicy {
    missingDataStrategy
    invalidDataStrategy
}

class SimulationReport {
    environmentalSummary
}

class EnvironmentThread {
    threadId
    status
}

class WeatherService {
    source
}

class WindConfiguration {
    windSpeed
    windDirection
}

SimulationEngine "1" -- "1" ParentSimulationProcess : controls >
ParentSimulationProcess "1" -- "1..*" FlightProcess : coordinates >
ParentSimulationProcess "1" -- "1" EnvironmentalDataSource : retrieves from >
EnvironmentalDataSource "1" -- "*" EnvironmentalData : provides >
EnvironmentalData "*" -- "1" AirControlArea : applies to >
EnvironmentalData "*" -- "1" TimeStep : may apply to >

ParentSimulationProcess "1" -- "1" SharedMemorySegment : stores environment in >
SharedMemorySegment "1" o-- "*" EnvironmentalData : contains >

FlightProcess "*" -- "1" EnvironmentalInfluenceModel : applies >
EnvironmentalInfluenceModel "1" -- "1" EnvironmentalData : uses >
EnvironmentalInfluenceModel "1" -- "1" AircraftState : adjusts >
EnvironmentalInfluenceModel "1" -- "1" AdjustedAircraftState : produces >

ParentSimulationProcess "1" -- "1" EnvironmentalPolicy : applies >
SimulationReport "1" o-- "*" EnvironmentalData : summarizes >

ParentSimulationProcess "1" -- "1" EnvironmentThread : spawns >
EnvironmentThread "1" -- "1" WeatherService : loads from >
WeatherService "1" -- "*" EnvironmentalData : provides >
EnvironmentalData "1" -- "1" WindConfiguration : includes >
EnvironmentThread "1" -- "1" SharedMemorySegment : writes to >

@enduml