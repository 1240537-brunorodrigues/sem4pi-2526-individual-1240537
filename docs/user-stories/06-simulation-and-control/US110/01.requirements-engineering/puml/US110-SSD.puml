@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam sequenceMessageAlign center
autonumber

actor "Simulation Engine" as Engine
participant ":Parent Simulation Process" as ParentProcess
participant ":Environmental Data Source" as EnvSource
participant ":Shared Memory" as SharedMemory
participant ":Flight Process" as FlightProcess
participant ":Simulation Report" as Report

activate Engine
activate ParentProcess

Engine -> ParentProcess : Start simulation with environmental influences

ParentProcess -> EnvSource : Retrieve environmental data for simulation context
activate EnvSource
EnvSource --> ParentProcess : Environmental data
deactivate EnvSource

ParentProcess --> ParentProcess : Validate environmental data

alt environmental data is valid

    ParentProcess -> SharedMemory : Store environmental data
    activate SharedMemory
    SharedMemory --> ParentProcess : Environmental data stored
    deactivate SharedMemory

    loop For each simulation time step

        ParentProcess -> SharedMemory : Publish environmental data for current step
        activate SharedMemory
        SharedMemory --> ParentProcess : Current step environment ready
        deactivate SharedMemory

        activate FlightProcess
        FlightProcess -> SharedMemory : Read current environmental data
        activate SharedMemory
        SharedMemory --> FlightProcess : Current environmental data
        deactivate SharedMemory

        FlightProcess --> FlightProcess : Apply environmental influences
        FlightProcess --> FlightProcess : Calculate adjusted movement and fuel data

        FlightProcess -> SharedMemory : Write adjusted aircraft state
        activate SharedMemory
        SharedMemory --> FlightProcess : Adjusted state stored
        deactivate SharedMemory
        deactivate FlightProcess

        ParentProcess --> ParentProcess : Continue step synchronization

    end

    ParentProcess -> Report : Add environmental influence summary
    activate Report
    Report --> ParentProcess : Report updated
    deactivate Report

else environmental data is missing or invalid

    ParentProcess --> ParentProcess : Apply missing-data policy
    ParentProcess -> Report : Log environmental data warning/error
    activate Report
    Report --> ParentProcess : Warning/error logged
    deactivate Report

end

ParentProcess --> Engine : Environmental influence processing completed

deactivate ParentProcess
deactivate Engine

@enduml