@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam sequenceMessageAlign center
autonumber

actor "PO" as PO
participant ":Parent Simulation Process" as ParentProcess
participant ":Environment Thread" as EnvironmentThread
participant ":Weather Service" as WeatherService
participant ":Shared Memory" as SharedMemory
participant ":Flight Process" as FlightProcess

activate PO

PO -> ParentProcess : Start simulation with environmental influences

activate ParentProcess
ParentProcess -> EnvironmentThread : Spawn environment thread at simulation start

activate EnvironmentThread
EnvironmentThread -> WeatherService : Load environmental configuration

activate WeatherService
WeatherService --> EnvironmentThread : Wind speed and wind direction
deactivate WeatherService

EnvironmentThread --> EnvironmentThread : Validate environmental data

alt environmental data is valid

    loop For each simulation time step

        EnvironmentThread -> SharedMemory : Write wind speed and wind direction\nfor current time step

        activate SharedMemory
        SharedMemory --> EnvironmentThread : Environmental data stored
        deactivate SharedMemory

        activate FlightProcess
        FlightProcess -> SharedMemory : Read current time step environmental data

        activate SharedMemory
        SharedMemory --> FlightProcess : Wind speed and wind direction
        deactivate SharedMemory

        FlightProcess --> FlightProcess : Apply environmental influence to movement
        deactivate FlightProcess

    end

else environmental data is missing or invalid

    EnvironmentThread --> ParentProcess : Report environmental data error
    ParentProcess --> ParentProcess : Apply missing/invalid data policy

end

EnvironmentThread --> ParentProcess : Environment thread completed or stopped
deactivate EnvironmentThread

ParentProcess --> PO : Environmental influence support initialized

deactivate ParentProcess
deactivate PO

@enduml