@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam sequenceMessageAlign center

autonumber

participant "ParentSimulationProcess" as ParentProcess
participant "EnvironmentThread" as EnvironmentThread
participant "WeatherServiceClient" as WeatherServiceClient
participant "EnvironmentalDataValidator" as EnvValidator
participant "EnvironmentalPolicy" as EnvPolicy
participant "SharedEnvironmentalDataManager" as SharedEnvManager
participant "FlightProcess" as FlightProcess
participant "EnvironmentalInfluenceModel" as InfluenceModel
participant "SharedAircraftStateWriter" as StateWriter
participant "SimulationReportUpdater" as ReportUpdater
participant "SimulationLogger" as Logger

activate ParentProcess

ParentProcess -> EnvironmentThread : create/start()

activate EnvironmentThread
EnvironmentThread -> WeatherServiceClient : loadWindConfiguration(simulationContext)

activate WeatherServiceClient
WeatherServiceClient --> EnvironmentThread : windConfiguration
deactivate WeatherServiceClient

EnvironmentThread -> EnvValidator : validate(windConfiguration)

activate EnvValidator
EnvValidator --> EnvironmentThread : validationResult
deactivate EnvValidator

alt wind configuration is valid

    EnvironmentThread -> ReportUpdater : addEnvironmentalSummary(windConfiguration)

    activate ReportUpdater
    ReportUpdater --> EnvironmentThread : summary added
    deactivate ReportUpdater

    loop for each simulation time step

        EnvironmentThread -> SharedEnvManager : writeEnvironmentForStep(currentStep, windConfiguration)

        activate SharedEnvManager
        SharedEnvManager --> EnvironmentThread : environment published
        deactivate SharedEnvManager

        activate FlightProcess

        FlightProcess -> SharedEnvManager : readEnvironmentForStep(currentStep)

        activate SharedEnvManager
        SharedEnvManager --> FlightProcess : environmentalData
        deactivate SharedEnvManager

        FlightProcess --> FlightProcess : calculate base aircraft state

        FlightProcess -> InfluenceModel : apply(baseState, environmentalData)

        activate InfluenceModel
        InfluenceModel --> FlightProcess : adjustedAircraftState
        deactivate InfluenceModel

        FlightProcess -> StateWriter : writeAdjustedState(adjustedAircraftState)

        activate StateWriter
        StateWriter --> FlightProcess : adjusted state written
        deactivate StateWriter

        deactivate FlightProcess

        ParentProcess --> ParentProcess : Continue step synchronization

    end

else wind configuration is missing

    EnvironmentThread -> EnvPolicy : handleMissingData(simulationContext)

    activate EnvPolicy
    EnvPolicy --> EnvironmentThread : defaultWindConfiguration / failure
    deactivate EnvPolicy

    alt default wind configuration is available

        EnvironmentThread -> ReportUpdater : addEnvironmentalWarning("Default wind configuration used")

        activate ReportUpdater
        ReportUpdater --> EnvironmentThread : warning added
        deactivate ReportUpdater

        EnvironmentThread -> Logger : logWarning("Default wind configuration used")

        activate Logger
        Logger --> EnvironmentThread : warning logged
        deactivate Logger

        loop for each simulation time step

            EnvironmentThread -> SharedEnvManager : writeEnvironmentForStep(currentStep, defaultWindConfiguration)

            activate SharedEnvManager
            SharedEnvManager --> EnvironmentThread : environment published
            deactivate SharedEnvManager

            activate FlightProcess

            FlightProcess -> SharedEnvManager : readEnvironmentForStep(currentStep)

            activate SharedEnvManager
            SharedEnvManager --> FlightProcess : environmentalData
            deactivate SharedEnvManager

            FlightProcess --> FlightProcess : calculate base aircraft state

            FlightProcess -> InfluenceModel : apply(baseState, environmentalData)

            activate InfluenceModel
            InfluenceModel --> FlightProcess : adjustedAircraftState
            deactivate InfluenceModel

            FlightProcess -> StateWriter : writeAdjustedState(adjustedAircraftState)

            activate StateWriter
            StateWriter --> FlightProcess : adjusted state written
            deactivate StateWriter

            deactivate FlightProcess

            ParentProcess --> ParentProcess : Continue step synchronization

        end

    else no valid default wind configuration

        EnvironmentThread -> Logger : logError("Environmental data unavailable")

        activate Logger
        Logger --> EnvironmentThread : error logged
        deactivate Logger

        EnvironmentThread --> ParentProcess : environment initialization failed

    end

else wind configuration is invalid

    EnvironmentThread -> EnvPolicy : handleInvalidData(validationResult)

    activate EnvPolicy
    EnvPolicy --> EnvironmentThread : handled / failure
    deactivate EnvPolicy

    EnvironmentThread -> Logger : logError("Invalid wind configuration")

    activate Logger
    Logger --> EnvironmentThread : error logged
    deactivate Logger

    EnvironmentThread --> ParentProcess : environment validation failed

end

deactivate EnvironmentThread
deactivate ParentProcess

@enduml