@startuml
title US114-CD

skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

package "flights.logging.server" #DDDDDD {
    class FlightsLoggingServer {
        - host: String
        - udpPort: int
        - httpPort: int
        + start()
        + stop()
    }

    class UDPReceiver {
        + receive()
        + updateProgressStore(update: FlightProgressUpdate)
    }

    class FlightProgressStore {
        + update(update: FlightProgressUpdate)
        + getCurrentProgress(): List<FlightProgressUpdate>
        + getByFlightId(flightId: String): FlightProgressUpdate
    }

    class FlightsVisualizationLogger {
        + logInfo(message: String)
        + logWarning(message: String)
        + logError(message: String)
    }
}

package "flights.logging.http" #DDDDDD {
    class HTTPServer {
        - port: int
        + start()
        + stop()
        + handleRequest(request: HttpRequest): HttpResponse
    }

    class StatusPageController {
        + getStatusPage(): HttpResponse
    }

    class FlightProgressApiController {
        + getCurrentProgress(): HttpResponse
    }

    class StatusPageRenderer {
        + render(): String
    }

    class FlightProgressDTOMapper {
        + toDTO(updates: List<FlightProgressUpdate>): List<FlightProgressDTO>
    }

    class HttpRequest {
        - method: String
        - path: String
    }

    class HttpResponse {
        - statusCode: int
        - contentType: String
        - body: String
    }
}

package "flights.logging.model" #DDDDDD {
    class FlightProgressUpdate {
        - flightId: String
        - aircraftId: String
        - simulationStep: int
        - timestamp: long
        - latitude: double
        - longitude: double
        - altitude: double
        - velocityX: double
        - velocityY: double
        - velocityZ: double
        - status: String
    }

    class FlightProgressDTO {
        - flightId: String
        - aircraftId: String
        - simulationStep: int
        - position: String
        - altitude: double
        - velocity: String
        - status: String
        - lastUpdatedAt: long
    }
}

package "browser" #DDDDDD {
    class StatusPage {
        + load()
    }

    class AJAXClientScript {
        + pollProgressEndpoint()
        + updatePage(data: List<FlightProgressDTO>)
    }

    class FlightProgressTableRenderer {
        + renderRows(data: List<FlightProgressDTO>)
        + showEmptyState()
        + showErrorState(message: String)
    }
}

FlightsLoggingServer --> UDPReceiver : contains >
FlightsLoggingServer --> HTTPServer : contains >
FlightsLoggingServer --> FlightProgressStore : maintains >
FlightsLoggingServer --> FlightsVisualizationLogger : logs >

UDPReceiver --> FlightProgressStore : updates >
UDPReceiver --> FlightProgressUpdate : receives >

HTTPServer --> StatusPageController : routes /status >
HTTPServer --> FlightProgressApiController : routes /api/flights/progress >
HTTPServer --> FlightsVisualizationLogger : logs >

StatusPageController --> StatusPageRenderer : renders >
StatusPageController --> HttpResponse : returns >

FlightProgressApiController --> FlightProgressStore : reads >
FlightProgressApiController --> FlightProgressDTOMapper : maps >
FlightProgressApiController --> HttpResponse : returns >

FlightProgressDTOMapper --> FlightProgressDTO : creates >
FlightProgressStore "1" o-- "*" FlightProgressUpdate

StatusPage --> AJAXClientScript : uses >
AJAXClientScript --> FlightProgressApiController : AJAX requests >
AJAXClientScript --> FlightProgressTableRenderer : updates table >
FlightProgressTableRenderer --> FlightProgressDTO : renders >

@enduml