@startuml
title US106-CD

skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

package "c.simulation.process" #DDDDDD {
    class ParentSimulationProcess {
        - processId: int
        - status: String
        + initializeFunctionThreads()
        + shutdownFunctionThreads()
    }
}

package "c.simulation.thread" #DDDDDD {
    class ParentThreadManager {
        + createRequiredThreads(context: ParentSynchronizationContext): int
        + createAdditionalThreads(): int
        + joinAllThreads(): int
        + stopAllThreads(): int
    }

    class ThreadRegistry {
        + registerThread(threadId: long, responsibility: String)
        + updateStatus(threadId: long, status: String)
        + getThreadByResponsibility(responsibility: String): DedicatedThread
    }

    class DedicatedThread {
        - threadId: long
        - responsibility: String
        - status: String
        + run()
    }

    class SafetyViolationDetectionThread {
        + run()
        + scanSharedMemory()
    }

    class ReportGenerationThread {
        + run()
        + compileSimulationResults()
        + respondToSafetyViolationEvents()
    }

    class AdditionalFunctionThread {
        - functionName: String
        + run()
    }

    class ThreadLifecycleManager {
        + createThread(functionPointer: String): long
        + requestStop(threadId: long)
        + join(threadId: long)
    }
}

package "c.simulation.shared" #DDDDDD {
    class SharedMemoryAccessor {
        + readAircraftPositions()
        + readSafetyViolations()
        + readSimulationStatus()
    }

    class SharedSimulationData {
        - aircraftPositions: AircraftPosition[]
        - safetyViolations: SafetyViolation[]
        - simulationStatus: int
    }

    class AircraftPosition {
        - aircraftId: String
        - timestamp: long
        - latitude: double
        - longitude: double
        - altitude: double
    }

    class SafetyViolation {
        - timestamp: long
        - involvedAircraftIds: String[]
        - description: String
    }
}

package "c.simulation.sync" #DDDDDD {
    class ParentSynchronizationContext {
        - sharedDataMutex: Mutex
        - reportMutex: Mutex
        - violationCondition: ConditionVariable
        - shutdownCondition: ConditionVariable
    }

    class MutexManager {
        + initializeMutex(mutex: Mutex): int
        + lock(mutex: Mutex): int
        + unlock(mutex: Mutex): int
        + destroyMutex(mutex: Mutex): int
    }

    class ConditionVariableManager {
        + initialize(condition: ConditionVariable): int
        + wait(condition: ConditionVariable, mutex: Mutex): int
        + signal(condition: ConditionVariable): int
        + broadcast(condition: ConditionVariable): int
        + destroy(condition: ConditionVariable): int
    }

    class Mutex {
        - name: String
        - initialized: boolean
    }

    class ConditionVariable {
        - name: String
        - initialized: boolean
    }
}

package "c.simulation.logging" #DDDDDD {
    class SimulationLogger {
        + logInfo(message: String)
        + logWarning(message: String)
        + logError(message: String)
    }
}

ParentSimulationProcess --> ParentThreadManager : creates/manages >
ParentSimulationProcess --> ParentSynchronizationContext : owns >
ParentSimulationProcess --> SimulationLogger : logs >

ParentThreadManager --> ThreadRegistry : registers >
ParentThreadManager --> ThreadLifecycleManager : creates/joins >
ParentThreadManager --> SafetyViolationDetectionThread : creates >
ParentThreadManager --> ReportGenerationThread : creates >
ParentThreadManager --> AdditionalFunctionThread : may create >

DedicatedThread <|-- SafetyViolationDetectionThread
DedicatedThread <|-- ReportGenerationThread
DedicatedThread <|-- AdditionalFunctionThread

SafetyViolationDetectionThread --> SharedMemoryAccessor : scans >
ReportGenerationThread --> SharedMemoryAccessor : reads >
SafetyViolationDetectionThread --> ParentSynchronizationContext : uses >
ReportGenerationThread --> ParentSynchronizationContext : uses >

SharedMemoryAccessor --> SharedSimulationData : accesses >
SharedSimulationData "1" o-- "*" AircraftPosition
SharedSimulationData "1" o-- "*" SafetyViolation

ParentSynchronizationContext *-- Mutex
ParentSynchronizationContext *-- ConditionVariable
MutexManager --> Mutex : manages >
ConditionVariableManager --> ConditionVariable : manages >
ConditionVariableManager --> Mutex : waits with >

ThreadRegistry "1" o-- "*" DedicatedThread

@enduml