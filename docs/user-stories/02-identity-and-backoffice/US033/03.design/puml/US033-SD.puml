@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam sequenceMessageAlign center

autonumber

actor "Administrator" as Admin
participant "ListUsersUI" as UI
participant "ListUsersController" as CTRL
participant "ListUsersService" as Service
participant "AuthorizationService" as AuthzService
participant "UserRepository" as UserRepo

activate Admin

Admin -> UI : Requests to list backoffice users

activate UI
UI -> CTRL : listUsers()

activate CTRL
CTRL -> Service : listUsers()

activate Service
Service -> AuthzService : requirePermission("LIST_USERS")

activate AuthzService
AuthzService --> Service : authorization granted
deactivate AuthzService

Service -> UserRepo : findAll()

activate UserRepo
UserRepo --> Service : List<User>
deactivate UserRepo

Service -> Service : sort users by email

alt users exist
    Service --> CTRL : List<User>
    CTRL --> UI : List<User>
    UI --> Admin : Display users with status and roles
else no users exist
    Service --> CTRL : Empty list
    CTRL --> UI : Empty list
    UI --> Admin : Display empty list message
end

deactivate Service
deactivate CTRL
deactivate UI
deactivate Admin

@enduml