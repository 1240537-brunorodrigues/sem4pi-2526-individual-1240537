@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam sequenceMessageAlign center

autonumber

actor "Administrator" as Admin
participant "EnableDisableUserUI" as UI
participant "EnableUserController" as EnableCTRL
participant "DisableUserController" as DisableCTRL
participant "EnableUserService" as EnableService
participant "DisableUserService" as DisableService
participant "AuthorizationService" as AuthzService
participant "UserRepository" as UserRepo
participant "User:\n targetUser" as TargetUser

activate Admin

Admin -> UI : Requests to disable or enable a user

activate UI
UI --> Admin : Requests user email and operation

Admin -> UI : Provides user email and operation

alt operation is enable
    UI -> EnableCTRL : enableUser(email)
    activate EnableCTRL
    EnableCTRL -> EnableService : enableUser(email)
    activate EnableService

    EnableService -> AuthzService : requirePermission("MANAGE_USERS")
    activate AuthzService
    AuthzService --> EnableService : authorization granted
    deactivate AuthzService

    EnableService -> UserRepo : findByEmail(email)
    activate UserRepo
    UserRepo --> EnableService : Optional<User>
    deactivate UserRepo

    alt user exists
        EnableService -> TargetUser : enable()
        activate TargetUser
        TargetUser --> EnableService : status updated
        deactivate TargetUser

        EnableService -> UserRepo : save(targetUser)
        activate UserRepo
        UserRepo --> EnableService : User
        deactivate UserRepo

        EnableService --> EnableCTRL : User
        EnableCTRL --> UI : User
        UI --> Admin : Display success message
    else user does not exist
        EnableService --> EnableCTRL : throws IllegalArgumentException
        EnableCTRL --> UI : error
        UI --> Admin : Display user not found message
    end

    deactivate EnableService
    deactivate EnableCTRL

else operation is disable
    UI -> DisableCTRL : disableUser(email)
    activate DisableCTRL
    DisableCTRL -> DisableService : disableUser(email)
    activate DisableService

    DisableService -> AuthzService : requirePermission("MANAGE_USERS")
    activate AuthzService
    AuthzService --> DisableService : authorization granted
    deactivate AuthzService

    DisableService -> UserRepo : findByEmail(email)
    activate UserRepo
    UserRepo --> DisableService : Optional<User>
    deactivate UserRepo

    alt user exists
        DisableService -> TargetUser : disable()
        activate TargetUser
        TargetUser --> DisableService : status updated
        deactivate TargetUser

        DisableService -> UserRepo : save(targetUser)
        activate UserRepo
        UserRepo --> DisableService : User
        deactivate UserRepo

        DisableService --> DisableCTRL : User
        DisableCTRL --> UI : User
        UI --> Admin : Display success message
    else user does not exist
        DisableService --> DisableCTRL : throws IllegalArgumentException
        DisableCTRL --> UI : error
        UI --> Admin : Display user not found message
    end

    deactivate DisableService
    deactivate DisableCTRL
end

deactivate UI
deactivate Admin

@enduml