@startuml

hide class
hide circle
hide methods
hide empty members
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

class User {
    email
    name
    phoneNumber
    status
}

class UserStatus {
    enabled
    disabled
}

class SecurityClearance {
    expirationDate
}

class SkillsAssessment {
    lastAssessmentDate
    validityPeriod
}

class Authorization {
    requiredPermission
}

User "1" -- "1" UserStatus : has >
User "1" -- "1" SecurityClearance : has >
User "1" -- "1" SkillsAssessment : has >
Authorization "1" -- "*" User : protects management of >

@enduml