@startuml

hide class
hide circle
hide methods
hide empty members
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

class User {
    email
    name
    phoneNumber
    status
}

class Role {
    name
}

class Credential {
    passwordHash
}

class SecurityClearance {
    expirationDate
}

class SkillsAssessment {
    lastAssessmentDate
    validityPeriod
}

class EmailDomain {
    domain
}

class Bootstrap {
    defaultData
}

Bootstrap "1" -- "*" User : initializes >
Bootstrap "1" -- "*" Role : initializes >
User "1" -- "1" Credential : has >
User "1" -- "1..*" Role : has >
User "1" -- "1" SecurityClearance : has >
User "1" -- "1" SkillsAssessment : has >
User "*" -- "1" EmailDomain : must belong to >

@enduml