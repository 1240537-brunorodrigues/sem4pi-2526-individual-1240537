title US031-CD

skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

package "ui.console" #DDDDDD {
    class RegisterUserUI {
        - controller: RegisterUserController
        - scanner: Scanner
        + run(): void
    }
}

package "controller" #DDDDDD {
    class RegisterUserController {
        - registerUserService: RegisterUserService
        + registerUser(request: RegisterUserRequest): User
    }
}

package "application" #DDDDDD {
    class RegisterUserService {
        - userRepository: UserRepository
        - roleRepository: RoleRepository
        - authorizationService: AuthorizationService
        + registerUser(request: RegisterUserRequest): User
    }

    class AuthorizationService {
        + requirePermission(permissionName: String): void
        + isAuthorized(permissionName: String): boolean
    }

    class RegisterUserRequest {
        - email: String
        - name: String
        - phoneNumber: String
        - password: String
        - roleNames: Set<String>
        - securityClearanceExpirationDate: LocalDate
        - skillsAssessmentDate: LocalDate
        - skillsAssessmentValidityPeriodInMonths: int
        + email(): String
        + name(): String
        + phoneNumber(): String
        + password(): String
        + roleNames(): Set<String>
        + securityClearanceExpirationDate(): LocalDate
        + skillsAssessmentDate(): LocalDate
        + skillsAssessmentValidityPeriodInMonths(): int
    }
}

package "bootstrap" #DDDDDD {
    class Bootstrap {
        - userRepository: UserRepository
        - roleRepository: RoleRepository
        + run(): void
    }
}

package "domain.user" #DDDDDD {
    class User {
        - email: Email
        - name: String
        - phoneNumber: PhoneNumber
        - credential: Credential
        - roles: Set<Role>
        - securityClearance: SecurityClearance
        - skillsAssessment: SkillsAssessment
        - enabled: boolean
        + User(...)
        + enable(): void
        + disable(): void
        + isEnabled(): boolean
        + isDisabled(): boolean
        + hasPermission(permission: Permission): boolean
    }

    class Email {
        - value: String
        + Email(value: String)
    }

    class PhoneNumber {
        - value: String
        + PhoneNumber(value: String)
    }

    class Credential {
        - passwordHash: String
        + Credential(rawPassword: String)
        + matches(rawPassword: String): boolean
    }

    class SecurityClearance {
        - expirationDate: LocalDate
        + SecurityClearance(expirationDate: LocalDate)
        + isValid(currentDate: LocalDate): boolean
    }

    class SkillsAssessment {
        - assessmentDate: LocalDate
        - validityPeriodInMonths: int
        + SkillsAssessment(assessmentDate: LocalDate, validityPeriodInMonths: int)
        + isValid(currentDate: LocalDate): boolean
    }
}

package "domain.auth" #DDDDDD {
    class Role {
        - name: String
        - permissions: Set<Permission>
        + name(): String
        + hasPermission(permission: Permission): boolean
    }

    class Permission {
        - name: String
        + Permission(name: String)
        + name(): String
    }
}

package "repository" #DDDDDD {
    interface UserRepository {
        + existsByEmail(email: Email): boolean
        + save(user: User): User
        + findByEmail(email: Email): Optional<User>
        + findAll(): List<User>
    }

    interface RoleRepository {
        + findByName(name: String): Optional<Role>
        + save(role: Role): Role
        + findAll(): List<Role>
    }
}

RegisterUserUI --> RegisterUserController : uses >
RegisterUserController --> RegisterUserService : uses >
RegisterUserService --> AuthorizationService : checks permission >
RegisterUserService --> UserRepository : checks/saves >
RegisterUserService --> RoleRepository : retrieves roles >
RegisterUserService --> RegisterUserRequest : reads >
RegisterUserService --> User : creates >
Bootstrap --> UserRepository : seeds users >
Bootstrap --> RoleRepository : seeds roles >

User *-- Email
User *-- PhoneNumber
User *-- Credential
User *-- SecurityClearance
User *-- SkillsAssessment
User "1" o-- "1..*" Role
Role "1" o-- "*" Permission

@enduml