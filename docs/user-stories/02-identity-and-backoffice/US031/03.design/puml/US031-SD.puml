@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam sequenceMessageAlign center

autonumber

actor "Administrator" as Admin
participant "RegisterUserUI" as UI
participant "RegisterUserController" as CTRL
participant "RegisterUserService" as Service
participant "AuthorizationService" as AuthzService
participant "UserRepository" as UserRepo
participant "RoleRepository" as RoleRepo
participant "Email" as Email
participant "User:\n newUser" as NewUser

activate Admin

Admin -> UI : Requests to register a new backoffice user

activate UI
UI --> Admin : Requests user data
deactivate UI

Admin -> UI : Provides user data

activate UI
UI -> CTRL : registerUser(request)

activate CTRL
CTRL -> Service : registerUser(request)

activate Service

Service -> AuthzService : isAuthorized(currentUser, REGISTER_USER)

activate AuthzService
AuthzService --> Service : true/false
deactivate AuthzService

alt administrator is authorized

    Service -> Email : Email(request.email)
    activate Email
    Email --> Service : email
    deactivate Email

    Service -> UserRepo : existsByEmail(email)

    activate UserRepo
    UserRepo --> Service : true/false
    deactivate UserRepo

    alt email does not exist

        loop for each selected role
            Service -> RoleRepo : findByName(roleName)

            activate RoleRepo
            RoleRepo --> Service : Optional<Role>
            deactivate RoleRepo
        end

        alt all roles exist and data is valid

            Service -> NewUser ** : User(email, name, phoneNumber, roles,\nsecurityClearance, skillsAssessment, credential)

            Service -> UserRepo : save(newUser)

            activate UserRepo
            UserRepo --> Service : saved
            deactivate UserRepo

            Service --> CTRL : UserDTO
            CTRL --> UI : Registration successful
            UI --> Admin : Display success message

        else invalid role or invalid data

            Service --> CTRL : Registration failed
            CTRL --> UI : Error
            UI --> Admin : Display error message

        end

    else email already exists

        Service --> CTRL : Registration failed
        CTRL --> UI : Error
        UI --> Admin : Display duplicated email error

    end

else administrator is not authorized

    Service --> CTRL : Access denied
    CTRL --> UI : Error
    UI --> Admin : Display access denied message

end

deactivate Service
deactivate CTRL
deactivate UI
deactivate Admin

@enduml