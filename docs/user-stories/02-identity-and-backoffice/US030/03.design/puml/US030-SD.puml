@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam sequenceMessageAlign center

autonumber

actor "User" as User
participant "AuthenticationUI" as UI
participant "AuthenticationController" as CTRL
participant "AuthenticationService" as AuthService
participant "UserRepository" as UserRepo
participant "User" as UserEntity
participant "Credential" as Credential
participant "AuthorizationService" as AuthorizationService
participant "Role" as Role

activate User

User -> UI : Requests authentication

activate UI
UI --> User : Requests email and password
deactivate UI

User -> UI : Provides email and password

activate UI
UI -> CTRL : authenticate(email, password)

activate CTRL
CTRL -> AuthService : authenticate(email, password)

activate AuthService
AuthService -> UserRepo : findByEmail(email)

activate UserRepo
UserRepo --> AuthService : Optional<User>
deactivate UserRepo

alt user exists

    AuthService -> UserEntity : isEnabled()
    activate UserEntity
    UserEntity --> AuthService : true/false
    deactivate UserEntity

    AuthService -> UserEntity : hasValidSecurityClearance(currentDate)
    activate UserEntity
    UserEntity --> AuthService : true/false
    deactivate UserEntity

    AuthService -> UserEntity : hasValidSkillsAssessment(currentDate)
    activate UserEntity
    UserEntity --> AuthService : true/false
    deactivate UserEntity

    AuthService -> Credential : matches(password)
    activate Credential
    Credential --> AuthService : true/false
    deactivate Credential

    alt user access conditions and credentials are valid
        AuthService --> CTRL : AuthenticatedUserSession
        CTRL --> UI : Authentication successful
        UI --> User : Display success message

        User -> UI : Requests protected functionality

        activate UI
        UI -> CTRL : authorize(session, requiredPermission)

        activate CTRL
        CTRL -> AuthorizationService : isAuthorized(user, requiredPermission)

        activate AuthorizationService
        AuthorizationService -> UserEntity : hasPermission(requiredPermission)

        activate UserEntity
        UserEntity -> Role : hasPermission(requiredPermission)

        activate Role
        Role --> UserEntity : true/false
        deactivate Role

        UserEntity --> AuthorizationService : true/false
        deactivate UserEntity

        AuthorizationService --> CTRL : true/false
        deactivate AuthorizationService

        alt user is authorized
            CTRL --> UI : Access granted
            UI --> User : Display protected functionality
        else user is not authorized
            CTRL --> UI : Access denied
            UI --> User : Display access denied message
        end

        deactivate CTRL
        deactivate UI

    else invalid credentials or invalid access conditions
        AuthService --> CTRL : Authentication failed
        CTRL --> UI : Error
        UI --> User : Display authentication error message
    end

else user does not exist
    AuthService --> CTRL : Authentication failed
    CTRL --> UI : Error
    UI --> User : Display authentication error message
end

deactivate AuthService
deactivate CTRL
deactivate UI
deactivate User

@enduml