@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam sequenceMessageAlign center

autonumber

actor "User" as UserActor
participant "AuthenticationUI" as UI
participant "AuthenticationController" as CTRL
participant "AuthenticationService" as AuthService
participant "UserRepository" as UserRepo
participant "User" as UserEntity
participant "AuthenticatedUserSession" as Session
participant "AuthorizationService" as AuthzService

activate UserActor

UserActor -> UI : Requests authentication
activate UI
UI --> UserActor : Requests email and password
UserActor -> UI : Provides email and password

UI -> CTRL : authenticate(email, password)
activate CTRL
CTRL -> AuthService : authenticate(email, password)
activate AuthService

AuthService -> UserRepo : findByEmail(email)
activate UserRepo
UserRepo --> AuthService : Optional<User>
deactivate UserRepo

alt user exists
    AuthService -> UserEntity : isDisabled()
    activate UserEntity
    UserEntity --> AuthService : true/false
    deactivate UserEntity

    AuthService -> UserEntity : matchesPassword(password)
    activate UserEntity
    UserEntity --> AuthService : true/false
    deactivate UserEntity

    AuthService -> UserEntity : hasValidSecurityClearance(currentDate)
    activate UserEntity
    UserEntity --> AuthService : true/false
    deactivate UserEntity

    AuthService -> UserEntity : hasValidSkillsAssessment(currentDate)
    activate UserEntity
    UserEntity --> AuthService : true/false
    deactivate UserEntity

    alt credentials and access conditions are valid
        AuthService -> Session : login(user)
        activate Session
        Session --> AuthService : session updated
        deactivate Session

        AuthService --> CTRL : User
        CTRL --> UI : User
        UI --> UserActor : Display authentication success message
    else invalid credentials or access conditions
        AuthService --> CTRL : throws IllegalArgumentException
        CTRL --> UI : error
        UI --> UserActor : Display authentication error message
    end
else user does not exist
    AuthService --> CTRL : throws IllegalArgumentException
    CTRL --> UI : error
    UI --> UserActor : Display authentication error message
end

deactivate AuthService
deactivate CTRL

UserActor -> UI : Requests protected functionality
UI -> AuthzService : requirePermission(permissionName)
activate AuthzService
AuthzService -> Session : isLoggedIn()
activate Session
Session --> AuthzService : true/false
deactivate Session

alt user is logged in
    AuthzService -> Session : currentUser()
    activate Session
    Session --> AuthzService : User
    deactivate Session

    AuthzService -> UserEntity : hasPermission(permission)
    activate UserEntity
    UserEntity --> AuthzService : true/false
    deactivate UserEntity

    alt user has permission
        AuthzService --> UI : authorization granted
        UI --> UserActor : Display protected functionality
    else user does not have permission
        AuthzService --> UI : throws SecurityException
        UI --> UserActor : Display access denied message
    end
else user is not logged in
    AuthzService --> UI : throws SecurityException
    UI --> UserActor : Display access denied message
end

deactivate AuthzService
deactivate UI
deactivate UserActor

@enduml